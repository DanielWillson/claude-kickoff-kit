{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git add *)", "Bash(git commit *)", "Bash(git status*)", "Bash(git diff*)", "Bash(git log *)", "Bash(git branch*)"
    ],
    "ask": [
      "Bash(git push *)", "Bash(gh pr merge *)"
    ],
    "deny": [
      "Read(~/.ssh/**)", "Read(~/.aws/**)", "Read(~/.npmrc)",
      "Read(**/*.pem)", "Read(**/*.token)", "Read(**/.env)", "Read(**/.env.*)",
      "Bash(gh auth token*)", "Bash(gh auth git-credential*)",
      "Bash(git credential*)", "Bash(git-credential*)",
      "Bash(security find-generic-password*)", "Bash(security find-internet-password*)",
      "Bash(kit-canary-denied*)"
    ]
  }
}

// The kit dogfooding its own PER-REPO floor (kickoff §1.3). The machine-wide HARD floor — no-bypass,
// credential denies, the OS sandbox — belongs in MANAGED settings (see templates/managed-settings.template.json
// and kickoff Part 0); it is hand-placed per machine and cannot live in a repo. This committed file is the soft,
// portable per-repo layer. Kept deliberately minimal (a docs repo): push behind a one-confirmation gate +
// credential-read denies. Takes effect on the next restart (permissions hot-reload). Remove if unwanted.
{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "ask": [
      "Bash(git push *)", "Bash(gh pr merge *)"
    ],
    "deny": [
      "Read(~/.ssh/**)", "Read(~/.aws/**)", "Read(~/.npmrc)",
      "Read(**/*.pem)", "Read(**/*.token)", "Read(**/.env)", "Read(**/.env.*)"
    ]
  }
}
